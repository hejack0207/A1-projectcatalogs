# category
{% for c,ts in tag_categories | dictsort %}
  ## [{{c}}]

      [
      {% for t in ts %}
  [{{t}}](#{{t}})
      {% endfor %}
      ]
{% endfor %}

# project tags
{% for k,v in tags.contents | dictsort %}
  [{{k}}](#{{k}})
{% endfor %}

# repos
{% for k,v in tags.contents | dictsort %}
## {{ k }}
    {% for repo in v %}
  + {{ repo.alias }} <{{ repo.url }}> 

      [
      {% for t in repo.tags %}
  [{{t}}](#{{t}})
      {% endfor %}
      ]
    {% endfor %}

{% endfor %}
