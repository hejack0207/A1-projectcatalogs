# category
## not in category
      {% for t in check.tags_not_in_category %}
  [{{t}}](#{{t}})
      {% endfor %}

{% for c,ts in tag_categories | dictsort %}
## {{c}}

      {% for t in ts %}
  [{{t}}](#{{t}})
      {% endfor %}
{% endfor %}

