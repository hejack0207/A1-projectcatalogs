local tpl=import 'tpl.jsn';
local repos=import 'repos.json';
local tag_category=import 'tag-category.json';

{
    tag_categories: tag_category.tag_categories,
    check: {
        tags_also_category: std.setInter(std.set(std.objectFields($.tag_categories)),
            std.set($.tags.names)),
        local func_merge(x,y)=std.setUnion(std.set(x),std.set(y)),
        tags_in_category: std.foldl(func_merge,[$.tag_categories[f] for f in std.objectFields($.tag_categories)],[]),
        tags_not_in_category: std.setDiff(std.set($.tags.names),self.tags_in_category),
    },
    tags: {
        names:: std.foldl((function (r,i) std.setUnion(r,i)),[ r.tags for r in $.repos_ ],[]),
        contents: {
            [n]: [r for r in $.repos_ if std.setMember(n,std.set(r.tags))]
            for n in $.tags.names
        }
    },

    repos_: [
        tpl.ghrepos + r for r in repos.repos
    ],

    repos:: {
        [std.strReplace(std.strReplace(r.alias,'-','_'),'.','_')]: r
        for r in self.repos_
    },

}
