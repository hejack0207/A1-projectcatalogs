local tpl=import 'tpl.jsn';

{
    topics:: {
        dev: {
            documentation: {
                restructed: [
                    $.repos.lb_2_jhipster,
                ],
            },
            scaffold: [
                $.repos.generator_jhipster,
                $.repos.lb_2_jhipster,
            ],
            template_prjs: [
                $.repos.SpringCloud,
            ],
            build: {
                make: [
                    $.repos.redis,
                    $.repos.git,
                    $.repos.vim,
                ],
                autotools: [
                    $.repos.tesseract,
                    $.repos.zsh,
                    $.repos.sqlite,
                    $.repos.openssh,
                    $.repos.tmux,
                    $.repos.postgres,
                ],
                cmake: [
                    $.repos.impala,
                    $.repos.Paddle,
                    $.repos.mysql_server,
                    $.repos.ccls,
                ],
            },
            deploy: {
                ansible: [
                    $.repos.gpdb_ansible,
                    $.repos.greenplum_ansible,
                    $.repos.ansible_pentaho_biserver_ce,
                    $.repos.hadoop_ansible,
                    $.repos.ansible_playbooks_cdh5,
                    $.repos.ansible_playbooks_cdh6,
                    $.repos.kubespray,
                ],
                docker_compose: [
                    $.repos.docker_pdi_ce,
                    $.repos.docker_gpdb5,
                    $.repos.apollo_build_scripts,
                ],
                docker: [
                    $.repos.docker_tomcat8,
                    $.repos.docker_mysql,
                    $.repos.docker_tomcat,
                    $.repos.kylin_docker,
                    $.repos.hadoop_docker,
                ],
                kubernetes: [
                    $.repos.kubespray,
                    $.repos.kubekit,
                    $.repos.hadoop_kerberos_helm,
                ],
            },
            testing: [
                $.repos.f2etest,
            ],
        },
        architect: {
            olap: {
                etl: {
                    pentaho: [
                        $.repos.pentaho_kettle,
                        $.repos.docker_pdi_ce,
                        $.repos.ansible_pentaho_biserver_ce,
                        $.repos.webkettle,
                        $.repos.kettle_manager,
                    ],
                    envelope: [
                        $.repos.envelope,
                    ],
                },
                bigdata: {
                    engine: [
                        $.repos.kylin,
                        $.repos.kylin_docker,
                    ],
                }
            },
            bigdata: {
                hadoop: [
                    $.repos.hadoop_docker,
                    $.repos.hadoop_ansible,
                    $.repos.hadoop_kerberos_helm,
                ],
                hbase: [
                ],
                hive: [
                ],
                cdh: [
                    $.repos.ansible_playbooks_cdh5,
                    $.repos.ansible_playbooks_cdh6,
                ],
                olap: $.topics.architect.olap.bigdata.engine,
            },
        },
        infra: {
            rdb: {
                postgres: [
                    $.repos.postgres,
                ],
                greenplum: [
                    $.repos.gpdb,
                    $.repos.docker_gpdb5,
                    $.repos.gpdb_ansible,
                    $.repos.greenplum_ansible,
                ],
            },
        },
        business: {
            gis: [
            ],
            text_mining: [
            ],
        },
    },

    project_category: [
        {
            name: "build.autotools",
            topics: $.topics.dev.build.autotools,
        },
        {
            name: "build.cmake",
            topics: $.topics.dev.build.cmake,
        },
        {
            name: "build.make",
            topics: $.topics.dev.build.make,
        },
        {
            name: "docker-compose",
            topics: $.topics.dev.deploy.docker_compose +
                [tpl.repos_sep] +
                $.topics.dev.deploy.docker,
        },
        {
            name: "ansible",
            topics: $.topics.dev.deploy.ansible,
        },
        {
            name: "kubernetes",
            topics: $.topics.dev.deploy.kubernetes,
        },
        {
            name: "etl",
            topics: $.topics.architect.olap.etl.pentaho +
                    [tpl.repos_sep] + 
                    $.topics.architect.olap.etl.envelope,
        },
        {
            name: "postgres",
            topics: $.topics.infra.rdb.postgres + $.topics.infra.rdb.greenplum,
        },
        {
            name: "olap",
            topics: $.topics.architect.olap.bigdata.engine,
        },
        {
            name: "scaffold",
            topics: $.topics.dev.scaffold,
        },
        {
            name: "template projects",
            topics: $.topics.dev.template_prjs,
        },
        {
            name: "big data",
            topics: $.topics.architect.bigdata.hadoop +
                $.topics.architect.bigdata.olap,
        },
        {
            name: "documentation",
            topics: $.topics.dev.documentation.restructed,
        },
    ],

    tags: {
        names:: std.foldl((function (r,i) std.setUnion(r,i)),[ r.tags for r in $.repos_ ],[]),
        contents: {
            [n]: [r for r in $.repos_ if std.setMember(n,std.set(r.tags))]
            for n in $.tags.names
        }
    },

