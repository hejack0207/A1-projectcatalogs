local tpl=import 'tpl.jsn';
local repos=import 'repos.json';

{
    tag_categories: {
        arch_agrithom: [],
        arch_ai: ["deep_learning"],
        arch_api: ["swagger", "graphql"],
        arch_backend_esb: [ "camel","servicemix" ],
        arch_backend_microservice_impl: [ "springcloud" ],
        arch_bigdata: [ "hadoop","cdh","impala","flink","spark"],
        arch_bigdata_category: [ "bigdata_awesome","bigdata_usecase","mpp_based" ,"sql_support"],
        arch_bigdata_dw: [ "greenplum","datawarehouse_impl","drill","pinot","presto" ],
        arch_bigdata_graphdb: [ "neo4j","orientdb","titan","cypher" ],
        arch_bigdata_olap: [ "kylin","clickhouse","mandrian","olap_impl" ],
        arch_frontend: [ "angular" ],
        arch_kernel: [],
        arch_platform_chrome: [],
        arch_platform_firefox: [],
        arch_security: [ "security_awesome","websecurity_awesome","security_cve" ],
        business: [ "agriculture_knowledge_graph","knn_graph" ],
        business_etl: [ "kettle","pentaho","envelope","datax","flinkx","etl_awesome" ],
        business_gis: [ "impalagis","sparkgis","gis_awesome","gis_impl" ],
        business_ocr: [ "tesseract","ocr_impl","ocr_awesome" ],
        dev_ci: [],
        dev_build: [ "autotools","cmake","make","maven" ],
        dev_deploy: [ "ansible","docker","docker_compose","helm","kubernetes" ],
        dev_design: [ "plantuml" ],
        dev_documentation: [ "asciidoc","markdown","restructured" ],
        dev_languages: [ "c","java","cpp","javascript" ],
        dev_language_tool: ["cpp_tool"],
        dev_scaffold: [ "jhipster","springcloud","archetype","swagger_angular","code_generator" ],
        dev_testing: [ "f2etest","benchmark" ],
        dev_vc: [ "git"],
        infra: [ "tomcat","redis","keepalived" ],
        infra_rdb: [ "sqlite","mysql","postgres" ],
        se_management: ["redmine"],
        se_webapp: ["webui"],
        tool_ui: [ "gui","tui","wui" ],
        tool_data_generator: [ "jsonnet" ],
        tool_editor: [ "vim","vim_plugin","vscode_plugin"],
        tool_terminal: [ "zsh","ssh","tmux" ],
    },
    check: {
        tags_also_category: std.setInter(std.set(std.objectFields($.tag_categories)),
            std.set($.tags.names)),
        local func_merge(x,y)=std.setUnion(std.set(x),std.set(y)),
        tags_in_category: std.foldl(func_merge,[$.tag_categories[f] for f in std.objectFields($.tag_categories)],[]),
        tags_not_in_category: std.setDiff(std.set($.tags.names),self.tags_in_category),
    },
    tags: {
        names:: std.foldl((function (r,i) std.setUnion(r,i)),[ r.tags for r in $.repos_ ],[]),
        contents: {
            [n]: [r for r in $.repos_ if std.setMember(n,std.set(r.tags))]
            for n in $.tags.names
        }
    },

    repos_: [
        tpl.ghrepos + r for r in repos.repos
    ],

    repos:: {
        [std.strReplace(std.strReplace(r.alias,'-','_'),'.','_')]: r
        for r in self.repos_
    },

}
