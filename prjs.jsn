local tpl=import 'tpl.jsn';

{
    topics:: {
        dev: {
            documentation: {
                restructed: [
                    $.repos.lb_2_jhipster,
                ],
            },
            build: {
                make: [
                    $.repos.redis,
                    $.repos.git,
                    $.repos.vim,
                ],
                autotools: [
                    $.repos.tesseract,
                    $.repos.zsh,
                    $.repos.sqlite,
                    $.repos.openssh,
                    $.repos.tmux,
                    $.repos.postgres,
                ],
                cmake: [
                    $.repos.impala,
                    $.repos.Paddle,
                    $.repos.mysql_server,
                    $.repos.ccls,
                ],
            },
            deploy: {
                ansible: [
                    $.repos.gpdb_ansible,
                    $.repos.greenplum_ansible,
                    $.repos.ansible_pentaho_biserver_ce,
                ],
                docker_compose: [
                    $.repos.docker_pdi_ce,
                    $.repos.docker_gpdb5,
                ],
                docker: [

                ],
                kubernetes: [

                ],
            },
        },
        architect: {
            olap: {
                etl: {
                    pentaho: [
                        $.repos.pentaho_kettle,
                        $.repos.docker_pdi_ce,
                        $.repos.ansible_pentaho_biserver_ce,
                        $.repos.webkettle,
                        $.repos.kettle_manager,
                    ],
                    envelope: [
                        $.repos.envelope,
                    ],
                },
                bigdata: {
                    engine: [
                        $.repos.kylin,
                    ],
                }
            },
        },
        infra: {
            rdb: {
                postgres: [
                    $.repos.postgres,
                ],
                greenplum: [
                    $.repos.gpdb,
                    $.repos.docker_gpdb5,
                    $.repos.gpdb_ansible,
                    $.repos.greenplum_ansible,
                ],
            },
        },
        business: {
            gis: [
            ],
            text_mining: [
            ],
        },
    },

    outputs: [
        {
            name: "build.autotools",
            topics: $.topics.dev.build.autotools,
        },
        {
            name: "build.cmake",
            topics: $.topics.dev.build.cmake,
        },
        {
            name: "build.make",
            topics: $.topics.dev.build.make,
        },
        {
            name: "docker-compose",
            topics: $.topics.dev.deploy.docker_compose,
        },
        {
            name: "ansible",
            topics: $.topics.dev.deploy.ansible,
        },
        {
            name: "etl",
            topics: $.topics.architect.olap.etl.pentaho +
                    [tpl.repos_sep] + 
                    $.topics.architect.olap.etl.envelope,
        },
        {
            name: "postgres",
            topics: $.topics.infra.rdb.postgres + $.topics.infra.rdb.greenplum,
        },
    ],

    repos_:: [
        tpl.myrepos + {
            repos_name: "lb-2-jhipster",
        },    
        tpl.ghrepos + {
            user: "tesseract-ocr",
            repos_name: "tesseract",
        },
        tpl.ghrepos + {
            user: "zsh-users",
            repos_name: "zsh",
        },
        tpl.ghrepos + {
            user: "mackyle",
            repos_name: "sqlite",
        },
        tpl.ghrepos + {
            user: "antonyantony",
            repos_name: "openssh",
        },
        tpl.ghrepos + {
            user: "tmux",
            repos_name: "tmux",
        },
        tpl.ghrepos + {
            user: "postgres",
            repos_name: "postgres",
        },
        tpl.ghrepos + {
            user: "PaddlePaddle",
            repos_name: "Paddle",
        },
        tpl.ghrepos + {
            user: "mysql",
            repos_name: "mysql-server",
        },
        tpl.ghrepos + {
            user: "MaskRay",
            repos_name: "ccls",
        },
        tpl.ghrepos + {
            user: "apache",
            repos_name: "impala",
        },
        tpl.ghrepos + {
            user: "antirez",
            repos_name: "redis",
        },
        tpl.ghrepos + {
            user: "git",
            repos_name: "git",
        },
        tpl.ghrepos + {
            user: "vim",
            repos_name: "vim",
        },
        tpl.ghrepos + {
            user: "zhicwu",
            repos_name: "docker-pdi-ce",
        },
        tpl.ghrepos + {
            user: "pentaho",
            repos_name: "pentaho-kettle",
        },
        tpl.ghrepos + {
            user: "bbotev01",
            repos_name: "gpdb5",
            alias: "docker-gpdb5",
        },
        tpl.ghrepos + {
            user: "andreasscherbaum",
            repos_name: "gpdb-ansible",
        },
        tpl.ghrepos + {
            user: "faer615",
            repos_name: "greenplum",
            alias: "greenplum-ansible",
            tags: ['ansible','greenplum',],
        },
        tpl.ghrepos + {
            user: "greenplum-db",
            repos_name: "gpdb",
        },
        tpl.ghrepos + {
            user: "oggers",
            repos_name: "ansible.pentaho-biserver-ce",
        },
        tpl.ghrepos + {
            user: "apache",
            repos_name: "kylin",
        },
        tpl.ghrepos + {
            user: "cloudera-labs",
            repos_name: "envelope",
        },
        tpl.ghrepos + {
            user: "majinju",
            repos_name: "kettle-manager",
        },
        tpl.ghrepos + {
            user: "JoeyBling",
            repos_name: "webkettle",
            forked: true,
        },
    ],

    repos:: {
        [std.strReplace(std.strReplace(r.alias,'-','_'),'.','_')]: r
        for r in self.repos_
    },

    ghtopics_:: [
        tpl.ghtopics + {
            repos_name: "olap",
        },
    ],

    ghtopcs:: {
        [std.strReplace(std.strReplace(t.alias,'-','_'),'.','_')]: t
        for t in self.ghtopcs_
    },
}