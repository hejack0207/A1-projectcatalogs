local tpl=import 'tpl.jsn';

{
    topics: {
        dev: {
            documentation: {
                restructed: [
                    $.repos.lb_2_jhipster,
                ],
            },
            build: {
                make: [],
                autotools: [
                    $.repos.tesseract,
                    $.repos.zsh,
                    $.repos.sqlite,
                    $.repos.openssh,
                    $.repos.tmux,
                    $.repos.postgres,
                ],
                cmake: [
                    $.repos.Paddle,
                    $.repos.mysql_server,
                    $.repos.ccls,
                ],
            },
        },
    },

    outputs: [
        {
            name: "build.autotools",
            topics: "dev.build.autotools",
        },
        {
            name: "build.cmake",
            topics: "dev.build.cmake",
        },
        {
            name: "build.make",
            topics: "dev.build.make",
        },
    ],

    repos_:: [
        tpl.myrepos + {
            repos_name: "lb-2-jhipster",
        },    
        tpl.ghrepos + {
            user: "tesseract-ocr",
            repos_name: "tesseract",
        },
        tpl.ghrepos + {
            user: "zsh-users",
            repos_name: "zsh",
        },
        tpl.ghrepos + {
            user: "mackyle",
            repos_name: "sqlite",
        },
        tpl.ghrepos + {
            user: "antonyantony",
            repos_name: "openssh",
        },
        tpl.ghrepos + {
            user: "tmux",
            repos_name: "tmux",
        },
        tpl.ghrepos + {
            user: "postgres",
            repos_name: "postgres",
        },
        tpl.ghrepos + {
            user: "PaddlePaddle",
            repos_name: "Paddle",
        },
        tpl.ghrepos + {
            user: "mysql",
            repos_name: "mysql-server",
        },
        tpl.ghrepos + {
            user: "MaskRay",
            repos_name: "ccls",
        },
    ],

    repos:: {
        [std.strReplace(r.repos_name,'-','_')]: r,
        for r in self.repos_
    }
}