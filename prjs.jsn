local tpl=import 'tpl.jsn';

{
    topics:: {
        dev: {
            documentation: {
                restructed: [
                    $.repos.lb_2_jhipster,
                ],
            },
            build: {
                make: [
                    $.repos.redis,
                    $.repos.git,
                    $.repos.vim,
                ],
                autotools: [
                    $.repos.tesseract,
                    $.repos.zsh,
                    $.repos.sqlite,
                    $.repos.openssh,
                    $.repos.tmux,
                    $.repos.postgres,
                ],
                cmake: [
                    $.repos.impala,
                    $.repos.Paddle,
                    $.repos.mysql_server,
                    $.repos.ccls,
                ],
            },
            deploy: {
                ansible: [

                ],
                docker_compose: [
                    $.repos.docker_pdi_ce,
                    $.repos.docker_gpdb5,
                ],
                docker: [

                ],
                kubernetes: [

                ],
            },
        },
        architect: {
            olap: {
                etl: {
                    pentaho: [
                        $.repos.pentaho_kettle,
                        $.repos.docker_pdi_ce,
                    ],
                },
            },
        },
        infra: {
            rdb: {
                postgres: [
                    $.repos.postgres,
                    $.repos.docker_gpdb5,
                ],
            },
        },
    },

    outputs: [
        {
            name: "build.autotools",
            topics: $.topics.dev.build.autotools,
        },
        {
            name: "build.cmake",
            topics: $.topics.dev.build.cmake,
        },
        {
            name: "build.make",
            topics: $.topics.dev.build.make,
        },
        {
            name: "docker-compose",
            topics: $.topics.dev.deploy.docker_compose,
        },
        {
            name: "pentaho",
            topics: $.topics.architect.olap.etl.pentaho,
        },
        {
            name: "relation database",
            topics: $.topics.infra.rdb.postgres,
        },
    ],

    repos_:: [
        tpl.myrepos + {
            repos_name: "lb-2-jhipster",
        },    
        tpl.ghrepos + {
            user: "tesseract-ocr",
            repos_name: "tesseract",
        },
        tpl.ghrepos + {
            user: "zsh-users",
            repos_name: "zsh",
        },
        tpl.ghrepos + {
            user: "mackyle",
            repos_name: "sqlite",
        },
        tpl.ghrepos + {
            user: "antonyantony",
            repos_name: "openssh",
        },
        tpl.ghrepos + {
            user: "tmux",
            repos_name: "tmux",
        },
        tpl.ghrepos + {
            user: "postgres",
            repos_name: "postgres",
        },
        tpl.ghrepos + {
            user: "PaddlePaddle",
            repos_name: "Paddle",
        },
        tpl.ghrepos + {
            user: "mysql",
            repos_name: "mysql-server",
        },
        tpl.ghrepos + {
            user: "MaskRay",
            repos_name: "ccls",
        },
        tpl.ghrepos + {
            user: "apache",
            repos_name: "impala",
        },
        tpl.ghrepos + {
            user: "antirez",
            repos_name: "redis",
        },
        tpl.ghrepos + {
            user: "git",
            repos_name: "git",
        },
        tpl.ghrepos + {
            user: "vim",
            repos_name: "vim",
        },
        tpl.ghrepos + {
            user: "zhicwu",
            repos_name: "docker-pdi-ce",
        },
        tpl.ghrepos + {
            user: "pentaho",
            repos_name: "pentaho-kettle",
        },
        tpl.ghrepos + {
            user: "bbotev01",
            repos_name: "gpdb5",
            alias: "docker-gpdb5",
        },
    ],

    repos:: {
        [if r.alias != null then std.strReplace(r.alias,'-','_') else std.strReplace(r.repos_name,'-','_')]: r,
        for r in self.repos_
    }
}