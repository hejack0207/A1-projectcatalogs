local tpl=import 'tpl.jsn';

{
    topics: {
        dev: {
            documentation: {
                restructed: [
                    $.repos.lb_2_jhipster,
                ],
            },
            build: {
                make: [],
                autotools: [
                    $.repos.tesseract,
                    $.repos.zsh,
                    $.repos.sqlite,
                ],
                cmake: [
                ],
            },
        },
    },

    repos_:: [
        tpl.myrepos + {
            repos_name: "lb-2-jhipster",
        },    
        tpl.ghrepos + {
            user: "tesseract-ocr",
            repos_name: "tesseract",
        },
        tpl.ghrepos + {
            user: "zsh-users",
            repos_name: "zsh",
        },
        tpl.ghrepos + {
            user: "mackyle",
            repos_name: "sqlite",
        },
    ],

    repos: {
        [std.strReplace(r.repos_name,'-','_')]: r,
        for r in self.repos_
    }
}