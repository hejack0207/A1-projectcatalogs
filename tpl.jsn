{
    repos: {
        site: "",
        user: "",
        repos_name: "",
        forked: false,
        alias: self.repos_name,
        url: if self.forked then self.site + "/hejack0207/" + self.repos_name 
            else self.site + "/" + self.user + "/" + self.repos_name,
        tags: [],
        release: null,
        shallow: false,
        score: 3,
    },
    ghrepos: self.repos + {
        site: "https://github.com",
    },
    repos_sep: self.ghrepos + {
        url: "",
        alias: "--------------------------",
    },
    myrepos: self.ghrepos + {
        user: "hejack0207",
    },
    ghtopics: self.ghrepos + {
        user: "topics",
    },
    tag: {
        name: null,
        ghtopics: null,
    },
    tags: [
        self.tag + {
            name: "olap",
        },
    ],
}